# UnityWall — environment template.
# Copy to .env.local for local dev; configure these as Vercel env vars in prod.

# Client-safe (will be inlined in browser; only the publishable/anon keys go here)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — NEVER expose to the client
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
RESEND_API_KEY=
RESEND_FROM="UnityWall <hello@unitywall.co>"
ADMIN_NOTIFY_EMAIL=support@unitywall.co

# Guest session JWT — 32-byte hex string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GUEST_JWT_SECRET=

# Public base URL used in QR codes and email links.
APP_BASE_URL=https://unitywall-psi.vercel.app

# Optional: Upstash Redis for rate limiting. Without these, middleware
# rate limits become no-ops (fine for local dev; required in production).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
